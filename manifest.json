{
    "manifest_version": 3,
    "name": "AI to Cat",
    "version": "1.0",
    "description": "Replaces instances of 'AI' and 'A.I.' with 'cat'. Also replaces 'large language model' and 'artificial intelligence'. Based on AI-to-Butt by Zach Bellay.",
    "author": "iam-py-test",
    "homepage_url": "https://github.com/iam-py-test/ai-to-cat",

    "browser_specific_settings": {
            "gecko": {
                "id": "ai-to-cat@iam-py-test.github.io",
                "strict_min_version": "128.0",
                "data_collection_permissions": {
                    "required": ["none"]
                }
            },
    },
    
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["replace.js"]
      }
    ]
  }
